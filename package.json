{
  "name": "splitwise-cli",
  "version": "1.0.0",
  "description": "Splitwise CLI",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.2.3",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-define-config": "^2.1.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "lint-staged": "^16.4.0",
    "simple-git-hooks": "^2.13.1",
    "vitest": "^4.0.18",
    "typescript": "^5.0.0",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.57.0"
  },
  "dependencies": {}
}
